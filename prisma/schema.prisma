// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth.js required models) ───────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
  monitors      Monitor[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core App Models ──────────────────────────────────────────────────────────

model Monitor {
  id              String        @id @default(cuid())
  userId          String
  name            String
  url             String
  interval        Int           // in minutes: 1, 5, 10, 60, 300
  active          Boolean       @default(true)
  telegramChatId  String?       // Telegram channel/group ID
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  lastCheckedAt   DateTime?
  lastStatus      CheckStatus?  // UP | DOWN | UNKNOWN
  lastStatusCode  Int?
  lastResponseMs  Int?
  uptimePercent   Float?        // calculated uptime %

  // SSL Monitoring
  sslValidUntil  DateTime?
  sslIssuer      String?

  // SEO Keywords
  keywords       String?   // Comma-separated keywords to track

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkLogs       CheckLog[]
  seoSnapshots    SeoSnapshot[]

  @@index([userId])
  @@index([active])
}

model CheckLog {
  id            String      @id @default(cuid())
  monitorId     String
  checkedAt     DateTime    @default(now())
  status        CheckStatus
  statusCode    Int?
  responseMs    Int?
  errorMessage  String?     @db.Text

  monitor       Monitor     @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId, checkedAt])
}

model SeoSnapshot {
  id              String   @id @default(cuid())
  monitorId       String
  snapshotAt      DateTime @default(now())
  title           String?
  metaDescription String?  @db.Text
  h1              String?
  hasRobotsTxt    Boolean?
  hasSitemap      Boolean?
  canonical       String?
  ogImage         String?
  wordCount       Int?
  internalLinks   Int?
  brokenLinks     Int?
  brokenUrls      Json?    // List of specific broken URLs found
  brokenAssets    Int?     // Count of broken images/scripts
  brokenAssetsList Json?   // List of specific broken assets
  contentHash     String?  // Hash of page text to detect changes
  foundUrls       Json?    // List of internal URLs discovered
  newUrls         Json?    // List of new URLs since last scan
  keywordsFound   Json?    // Result of keyword search { keyword: found_bool }
  pageSpeedScore  Int?     // 0–100 if available

  monitor         Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId, snapshotAt])
}

model DailyReport {
  id              String   @id @default(cuid())
  userId          String
  reportDate      DateTime // the date this report covers
  generatedAt     DateTime @default(now())
  totalMonitors   Int
  totalChecks     Int
  totalDownEvents Int
  avgUptimePercent Float
  reportJson      Json     // full JSON report payload

  @@index([userId, reportDate])
}

model Project {
  id          String     @id
  name        String
  description String?    @default("")
  createdAt   DateTime?  @default(now()) @map("created_at")
  documents   Document[]

  @@map("projects")
}

model Document {
  id        String    @id
  projectId String    @map("project_id")
  title     String
  content   String?   @default("")
  updatedAt DateTime? @default(now()) @map("updated_at")
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("documents")
}

enum CheckStatus {
  UP
  DOWN
  UNKNOWN
}

